// host-fs.wit — Sandboxed host filesystem interface (imported by plugins).
//
// Plugins declare which paths they need access to in `[plugin.inputs]` of their
// module TOML. The host validates these declarations before granting access.
// Plugins cannot access paths outside their declared scope.

package fsn:plugin@0.1.0;

interface host-fs@0.1.0 {
    /// Filesystem operation errors.
    variant fs-error {
        /// Path is outside the plugin's declared access scope.
        access-denied(string),
        /// File or directory does not exist.
        not-found(string),
        /// I/O error reading or writing.
        io-error(string),
    }

    /// Read the contents of a file at `path`.
    ///
    /// Returns `fs-error::access-denied` if `path` was not declared in the manifest.
    read-file: func(path: string) -> result<string, fs-error>;

    /// Write `content` to `path`, creating parent directories if needed.
    ///
    /// Returns `fs-error::access-denied` if `path` was not declared in the manifest.
    write-file: func(path: string, content: string, mode: u32) -> result<_, fs-error>;

    /// Check whether `path` exists.
    path-exists: func(path: string) -> result<bool, fs-error>;

    /// List directory entries at `path`.
    list-dir: func(path: string) -> result<list<string>, fs-error>;
}
