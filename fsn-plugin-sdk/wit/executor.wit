// executor.wit — Plugin executor interface.
//
// Every FreeSynergy plugin must export this interface.
// The host calls `manifest` once after loading, then `execute` for each command.

package fsn:plugin@0.1.0;

interface executor@0.1.0 {
    // ── Types ────────────────────────────────────────────────────────────────

    /// Plugin identity and supported commands.
    record plugin-manifest {
        /// Unique plugin identifier (e.g. "zentinel").
        id: string,
        /// Semantic version string (e.g. "0.1.0").
        version: string,
        /// Human-readable description.
        description: string,
        /// Commands this plugin handles (e.g. ["deploy", "clean"]).
        commands: list<string>,
    }

    /// Context passed to `execute` — describes the current deployment state.
    record plugin-context {
        /// Command to execute (must be one of `plugin-manifest.commands`).
        command: string,
        /// Plugin-specific inputs as a JSON string.
        /// Schema is defined per-plugin; the host passes values from module TOML `[plugin.inputs]`.
        inputs-json: string,
        /// Information about the project being deployed.
        project: project-info,
        /// Host the deployment targets.
        host: host-info,
        /// Services defined in the project.
        services: list<service-info>,
    }

    /// Minimal project information available to plugins.
    record project-info {
        /// Project name (from `[project] name`).
        name: string,
        /// Project domain (from `[project] domain`).
        domain: string,
    }

    /// Target host information.
    record host-info {
        /// Host name.
        name: string,
        /// Host domain / IP.
        address: string,
    }

    /// A service instance in the deployment.
    record service-info {
        /// Service name.
        name: string,
        /// Container image.
        image: string,
        /// Assigned subdomain (if any).
        subdomain: option<string>,
        /// Whether this service is the proxy.
        is-proxy: bool,
    }

    /// Output produced by the plugin — files to write and commands to run.
    record plugin-response {
        /// Files the host should write to disk.
        files: list<output-file>,
        /// Shell commands the host should execute (in order).
        commands: list<shell-command>,
        /// Non-empty if the plugin encountered an error.
        error: string,
        /// Optional human-readable status message for the TUI.
        status-message: option<string>,
    }

    /// A file the plugin wants the host to write.
    record output-file {
        /// Absolute destination path on the host.
        dest: string,
        /// File content as UTF-8 text.
        content: string,
        /// Unix file mode (e.g. 0o644).
        mode: u32,
    }

    /// A shell command the plugin wants the host to run.
    record shell-command {
        /// The shell command string (passed to `sh -c`).
        cmd: string,
        /// Optional working directory.
        cwd: option<string>,
        /// Environment variables to set.
        env: list<tuple<string, string>>,
    }

    // ── Functions ─────────────────────────────────────────────────────────────

    /// Return the plugin manifest.
    ///
    /// Called once by the host immediately after loading.
    /// Must be pure (no side effects).
    manifest: func() -> plugin-manifest;

    /// Execute a command with the given context.
    ///
    /// The host calls this for each deployment step.
    /// Returns a `plugin-response` describing what the host should do.
    execute: func(ctx: plugin-context) -> plugin-response;
}
