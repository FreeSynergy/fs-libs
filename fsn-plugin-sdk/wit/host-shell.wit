// host-shell.wit — Sandboxed host shell interface (imported by plugins).
//
// Plugins declare which commands they need to run in `[plugin.commands]`
// of their module TOML. The host validates these against the declaration
// before executing. Wildcard commands are not permitted.

package fsn:plugin@0.1.0;

interface host-shell@0.1.0 {
    /// Shell execution errors.
    variant shell-error {
        /// Command was not declared in the plugin manifest.
        not-permitted(string),
        /// Process exited with non-zero status.
        exit-failure(u32),
        /// Failed to spawn the process.
        spawn-error(string),
    }

    /// Run a shell command that was declared in `[plugin.commands]`.
    ///
    /// `cmd` must exactly match one of the declared command prefixes.
    /// Returns stdout as a string on success.
    run: func(
        cmd: string,
        cwd: option<string>,
        env: list<tuple<string, string>>,
    ) -> result<string, shell-error>;
}
